{
  "extends": "@gehirn/tsconfig/base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@server/*": ["./server/*"],
      "@modules/*": ["./modules/*"]
    },
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "./dist-server",
    "rootDir": ".",
    "noEmit": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false
  },
  "include": ["server"],
  "exclude": ["node_modules", "dist", "modules/**/__tests__/**", "modules/**/*.test.ts", "modules/**/*.tsx", "modules/**/hooks/**"]
}
