{
  "name": "@gehirn/auth-providers",
  "version": "0.1.0",
  "private": true,
  "description": "Provider-agnostic authentication interfaces with Supabase/Auth0 adapters.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "peerDependencies": {
    "@supabase/supabase-js": "*",
    "express": "*",
    "jsonwebtoken": "*"
  },
  "peerDependenciesMeta": {
    "@supabase/supabase-js": {
      "optional": true
    },
    "express": {
      "optional": true
    },
    "jsonwebtoken": {
      "optional": true
    }
  },
  "scripts": {
    "build": "npx --yes -p typescript tsc -p tsconfig.json",
    "typecheck": "npx --yes -p typescript tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test tests/*.test.mjs"
  }
}
